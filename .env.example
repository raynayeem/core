# Backend runtime environment variables
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/core-cms?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret

# Frontend build-time environment variables (Vite)
VITE_API_URL=/api
VITE_UPLOAD_URL=

# Deployment variables
APP_UPSTREAM_PORT=8080
APP_SERVER_NAME=_
APP_DOMAIN=
APP_DOMAIN_ALIASES=
LETSENCRYPT_EMAIL=
APP_GIT_REMOTE=origin
APP_GIT_BRANCH=main
APP_SEED_ENDPOINT=/api/seed